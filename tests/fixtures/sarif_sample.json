{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "DemoTool",
          "version": "1.0.0",
          "informationUri": "https://example.invalid",
          "rules": [
            {
              "id": "DEMO001",
              "shortDescription": {"text": "SQL injection via string concatenation"},
              "fullDescription": {"text": "Detected SQL query built by concatenating user input."},
              "defaultConfiguration": {"level": "error"},
              "properties": {
                "tags": ["security", "CWE-89"],
                "security-severity": "8.8",
                "confidence": "high"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "DEMO001",
          "level": "error",
          "message": {"text": "Query built from string concat"},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "src/api/users.py"},
                "region": {"startLine": 42}
              }
            }
          ],
          "properties": {
            "security-severity": "8.8",
            "cwe": ["CWE-89"],
            "owasp": ["A03:2021"],
            "confidence": "high"
          }
        }
      ]
    }
  ]
}