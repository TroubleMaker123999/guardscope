# Vite dev server proxy target for the FastAPI backend.
# Used only in development. In production, serve the SPA from a reverse proxy.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Base path used by the frontend when calling the backend. Defaults to "/api".
# When the SPA is served by the FastAPI app, keep the default and configure
# the dev proxy. When served by another reverse proxy, set this accordingly.
VITE_API_BASE_URL=/api